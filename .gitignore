# -------------------------------
# Build artifacts
# -------------------------------
*.tgz

# Packaged Helm charts (generated by make)
helm-base-charts/**/*.tgz
/usr/local/share/dockwright/charts/

# -------------------------------
# Local environment / temp files
# -------------------------------
*.swp
*.swo
*.tmp
*.log
*.bak

# macOS Finder clutter
.DS_Store

# JetBrains / IntelliJ
.idea/
*.iml

# VSCode
.vscode/

# -------------------------------
# Shell script executables created during install
# (Never commit globally installed binaries)
# -------------------------------
/usr/local/bin/dockwright

# -------------------------------
# Python virtual environments (if used)
# -------------------------------
.venv/
venv/
ENV/

# -------------------------------
# Optional: ignore local config copies
# The real config is committed; the installed one lives in /etc
# -------------------------------
/etc/dockwright.conf